# Copy to ".env" and adjust for local development.

# Business contact inbox shown on the site.
VITE_CONTACT_EMAIL=shreenirmaldntransport@gmail.com

# Production domain (NO trailing slash). Injected into index.html for og:image,
# canonical, and JSON-LD structured data. Set this to the live domain before
# building for production.
VITE_SITE_URL=https://www.yourdomain.com

# Google Analytics 4 measurement id (e.g. G-XXXXXXXXXX). Leave blank to disable
# analytics entirely (no script is loaded).
VITE_GA_ID=

# Owned FastAPI backend endpoints. Point these at the deployed API in production
# (e.g. https://api.yourdomain.com/api/quotes).
VITE_QUOTES_API=http://localhost:8000/api/quotes
VITE_WAITLIST_API=http://localhost:8000/api/waitlist
