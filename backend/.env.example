# Copy to ".env" and fill in. Used by backend/main.py for SMTP delivery.
# For Gmail: create an App Password (Account > Security > App passwords) and
# use it as SMTP_PASSWORD with SMTP_USER = your full gmail address.

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASSWORD=your-app-password

# Where quote requests are delivered
MAIL_TO=shreenirmaldntransport@gmail.com
MAIL_FROM=your-sender@gmail.com
MAIL_FROM_NAME=Shri Nirmal Logistics - Website

# Comma-separated front-end origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
